# ==========================================
# AgroSetu Environment Configuration
# ==========================================

# ------------------------------------------
# Backend Configuration (Google Lens AI)
# ------------------------------------------
# Used by Playwright to login and use Google Lens for crop disease detection.
GOOGLE_EMAIL="your_email@gmail.com"
GOOGLE_PASSWORD="your_password"

# ------------------------------------------
# Backend Configuration (OKF Chat AI)
# ------------------------------------------
# SambaNova (LLM) configuration
SAMBANOVA_API_KEY="your_sambanova_api_key_here"

# ------------------------------------------
# Frontend Configuration (Firebase)
# ------------------------------------------
# Vite requires frontend variables to be prefixed with VITE_
# These are used for authentication and connecting to the Firebase project.
VITE_FIREBASE_API_KEY="your_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your_firebase_auth_domain"
VITE_FIREBASE_PROJECT_ID="your_firebase_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_firebase_storage_bucket"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_firebase_messaging_sender_id"
